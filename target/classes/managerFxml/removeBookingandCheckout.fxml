<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="800.0" styleClass="registerScene" stylesheets="@../CSS/Style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.mycompany.managerController.removeBookingandCheckoutController">
   <children>
      <AnchorPane prefHeight="600.0" prefWidth="800.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label layoutX="136.0" layoutY="73.0" text="Available Booking information">
               <font>
                  <Font name="Arial" size="40.0" />
               </font>
            </Label>
            <TableView fx:id="infoTable" layoutX="136.0" layoutY="142.0" prefHeight="200.0" prefWidth="391.0">
              <columns>
                <TableColumn fx:id="colBookingId" prefWidth="75.0" text="Booking Id" />
                <TableColumn fx:id="colRoomNum" prefWidth="111.20001220703125" text="Room Number" />
                  <TableColumn fx:id="colRoomStatus" prefWidth="95.20001220703125" text="Room Status" />
